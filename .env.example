# =============================================================================
# Modèle de configuration — copier ce fichier en `.env` et remplir les valeurs.
# Le fichier `.env` est ignoré par git (ne jamais committer de secrets).
# =============================================================================

# --- Base de données PostgreSQL (Neon, Supabase, Railway...) ---
# Laisser vide en local → SQLite automatique (data/offers.db)
DATABASE_URL=postgresql://user:password@host/dbname

# --- URL du frontend déployé (pour restreindre le CORS) ---
# Laisser vide en local → CORS ouvert
FRONTEND_URL=https://votre-app.vercel.app

# --- URL de l'API utilisée par le frontend au build (frontend/scripts/build.js) ---
# Laisser vide en local → http://localhost:8000/api
API_URL=

# --- Identifiants France Travail (scraper) ---
FT_CLIENT_ID=
FT_CLIENT_SECRET=
